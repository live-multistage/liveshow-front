# Backend API base URL (include /api suffix)
NEXT_PUBLIC_API_URL=http://localhost:8080/api

# Opaque token gating /broadcaster-dock/<token> — must match the OBS plugin's
# LIVESHOW_DOCK_TOKEN env var exactly. Never a NEXT_PUBLIC_ var (server-only check
# in middleware.ts). Generate a real random value for actual deployments; this is
# a placeholder for local dev.
LIVESHOW_DOCK_TOKEN=change-me-dock-token
